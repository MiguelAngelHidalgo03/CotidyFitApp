rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && firestore.exists(/databases/(default)/documents/admin_users/$(request.auth.uid));
    }

    match /nutrition/recipes/{recipeId}/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /training/exercises/{exerciseId}/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /training/routines/{routineId}/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}